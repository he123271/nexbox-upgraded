{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NexBox",
  "version": "3.9.4",
  "identifier": "NexBox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NexBox",
        "width": 1230,
        "height": 771,
        "minWidth": 1230,
        "minHeight": 771,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "../nvidiaProfileInspector.exe",
      "../nvidiaProfileInspector.exe.config",
      "../Reference.xml",
      "../power-plans/*",
      "../MiSans-Medium.ttf",
      "../monitor/bin/Release/net48/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
